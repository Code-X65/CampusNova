{
    "name": "campusnova-monorepo",
    "private": true,
    "version": "0.0.0",
    "engines": {
        "node": "^20.0.0"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\""
    },
    "devDependencies": {
        "turbo": "^2.4.4",
        "prettier": "^3.5.3"
    }
}